{
  "name": "@haemmid/pi-processes",
  "version": "0.9.0",
  "description": "Agent-facing background process manager for Pi and pi-web automation workflows.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "homepage": "https://github.com/haemmid/pi-processes#readme",
  "bugs": {
    "url": "https://github.com/haemmid/pi-processes/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "pi-web",
    "processes",
    "background-processes",
    "dev-server",
    "astro",
    "vite"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/haemmid/pi-processes"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@aliou/sh": "^0.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@earendil-works/pi-coding-agent": "0.75.1",
    "@types/node": "^25.0.10",
    "typebox": "^1.1.24",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.26.1",
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  }
}
